/* ── Settings ───────────────────────────────────────────────── */

#settings-body {
    height: 1fr;
}

#settings-list {
    min-width: 18;
    background: $panel;
    border-right: solid $primary;
}

#settings-content {
    width: 1fr;
    padding: 1 2;
    height: 1fr;
    background: $surface;
}

.settings-pane {
    height: auto;
}

#settings-actions {
    height: auto;
    margin-top: 2;
    align: left middle;
}
