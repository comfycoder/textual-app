/* ── Pagination ─────────────────────────────────────────────── */

#page-body {
    padding: 1 2;
    height: 1fr;
    background: $surface;
}

#page-controls {
    height: auto;
    padding: 1 0;
    align: left middle;
    background: $panel;
    border-top: solid $primary;
}

#page-label {
    width: 1fr;
    content-align: center middle;
}
