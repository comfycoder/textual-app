/* ── Pagination ─────────────────────────────────────────────── */

#page-body {
    padding: 1 2;
    height: 1fr;
    background: $surface;
}

#page-controls {
    height: auto;
    align: left middle;
    background: $panel;
    border-top: solid $primary;
}

/* Give the PaginationBar the same vertical rhythm as the old button row. */
#page-controls > PaginationBar {
    padding: 1 0;
}
