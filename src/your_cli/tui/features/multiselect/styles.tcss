/* ── Multi-select ───────────────────────────────────────────── */

#ms-body {
    padding: 1 2;
    height: 1fr;
    background: $surface;
}

#ms-hint {
    height: auto;
    padding: 0 1;
    margin-bottom: 1;
}

#ms-actions {
    height: auto;
    padding: 1 0;
    align: left middle;
    background: $panel;
    border-top: solid $primary;
}

#ms-count {
    width: 1fr;
    content-align: right middle;
    color: $text-muted;
    padding-right: 2;
}
