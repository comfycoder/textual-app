/* ── Theme toggle ───────────────────────────────────────────── */

#theme-body {
    height: 1fr;
}

#theme-list {
    min-width: 20;
    background: $panel;
    border-right: solid $primary;
}

#theme-preview {
    width: 1fr;
    padding: 1 4;
    height: 1fr;
    background: $surface;
}

#theme-active-label {
    margin-bottom: 1;
    color: $accent;
}
