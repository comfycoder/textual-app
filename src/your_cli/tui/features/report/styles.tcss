/* ── Report ─────────────────────────────────────────────────── */

#report-body {
    height: 1fr;
}

#report-list {
    min-width: 24;
    background: $panel;
    border-right: solid $primary;
}

#report-content {
    width: 1fr;
    padding: 1 2;
    height: 1fr;
    background: $surface;
}

#report-md {
    height: 1fr;
}
